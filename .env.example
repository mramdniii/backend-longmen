# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/appdb
DATABASE_URL_SYNC=postgresql+psycopg2://user:password@localhost:5432/appdb

# ── JWT ───────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Security ──────────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=3
ACCOUNT_LOCK_DURATION_MINUTES=30
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=60

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=AuthService
